  "sheet_mvu_character": {
    "uid": "sheet_mvu_character",
    "name": "角色",
    "sourceData": {
      "note": "对应 MVU 根键「角色档案」；本表在界面中显示名为「角色」。「档案ID」= 变量里该条目的键（可与姓名相同或独立 ID）。\n\n【登场与建档 · 变量更新规则】\n- 正文出现有戏份/有台词/高颜值或性格突出的女性角色（含路人、学姐、教师等）时：本回合须插入或补全一行；禁止留空列、禁止 JSON 列为空 {} 糊弄。\n- 初始化须覆盖：①基础信息 ②性格JSON（≥2 标签）③性癖JSON、隐藏性癖 ④身体信息列 ⑤服装状态JSON ⑥身体部位物理状态JSON（至少含脸部、手部、乳房、乳头、小穴、脚部）⑦敏感点开发JSON（敏感等级、生理反应、开发细节）⑧数值列 ⑨身份标签JSON、当前综合生理描述。\n\n【状态】出场中|暂时退场。【性癖】100 触变质后性癖开发值归零（与变量规则一致）。\n【数值】好感度约 ±(1~3)；发情值言语撩拨 +(5~15)；性癖开发 +(2~8)。\n【级联】规则或游戏时间跨日时须更新本表相关列。\n\n【JSON】须合法，双引号键。",
      "initNode": "开局每人一行；新角色登场 insertRow 并填满各列与 JSON。",
      "deleteNode": "角色永久退场且不再引用时可删行。",
      "updateNode": "随剧情、规则、跨日结算更新。",
      "insertNode": "新角色登场；档案ID 唯一。"
    },
    "content": [
      [
        null,
        "档案ID",
        "姓名",
        "状态",
        "描写",
        "当前内心想法",
        "隐藏性癖",
        "年龄",
        "身高",
        "体重",
        "三围",
        "体质特征",
        "好感度",
        "性癖开发值",
        "发情值",
        "性格JSON",
        "性癖JSON",
        "敏感点开发JSON",
        "服装状态JSON",
        "身体部位物理状态JSON",
        "身份标签JSON",
        "当前综合生理描述"
      ]
    ],
    "updateConfig": {
      "uiSentinel": -1,
      "contextDepth": 4,
      "updateFrequency": -1,
      "batchSize": 4,
      "skipFloors": -1
    },
    "exportConfig": {
      "enabled": true,
      "splitByRow": true,
      "entryName": "角色",
      "entryType": "keyword",
      "keywords": "姓名",
      "preventRecursion": true,
