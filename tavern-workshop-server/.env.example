# Discord OAuth App credentials
# Create at: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Your Discord user ID (for admin access)
# Get from Discord: Settings -> Advanced -> Developer Mode -> right click your name -> Copy User ID
ADMIN_DISCORD_ID=your_discord_user_id

# CORS origin (set to your frontend URL in production, or * for development)
CORS_ORIGIN=*

# Database URL (set automatically by Render)
# DATABASE_URL=postgresql://...
